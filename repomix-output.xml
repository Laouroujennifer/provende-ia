              <MixingBowl items={recipe} onRemove={handleRemoveIngredient} />

              {/* Liste de la recette */}
              <div className="mt-8 space-y-2 max-h-60 overflow-y-auto pr-2">
                <AnimatePresence initial={false}>
                  {recipe.map((item: RecipeItem, index: number) => {
