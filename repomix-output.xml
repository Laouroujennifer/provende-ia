            <div className="bg-indigo-600 p-2 rounded-lg text-white">
              <ChefHat size={20} />
            </div>
            <h1 className="text-xl font-bold bg-clip-text text-transparent bg-linear-to-r from-indigo-600 to-purple-600">
              ProvendeBuilder
            </h1>
          </div>
