@import "tailwindcss";

@layer base {
  /* Fond noir global sur toute l'app */
  html, body, #root {
    background-color: #0A0A0A;
    color: #F5F5F5;
    min-height: 100vh;
  }
}

/* ─── PALETTE DE COULEURS DE L'APP ─────────────────────────────────────────
   Fond principal       : #0A0A0A (presque noir)
   Cartes intérieures   : #1A1A1A (gris foncé)
   Bordures discrètes   : #2A2A2A
   Texte titre          : #FFFFFF blanc pur
   Texte courant        : #BBBBBB gris clair
   Texte secondaire     : #888888 gris moyen
   Accent orange CTA    : #FF6800
   Accent orange hover  : #FF8533
   Accent orange dark   : #E55A00
─────────────────────────────────────────────────────────────────────────── */

/* Utilitaires personnalisés */
.card-pro {
  background-color: #1A1A1A;
  border: 1px solid #2A2A2A;
  border-radius: 1.5rem;
}

.btn-premium {
  background-color: #FF6800;
  color: white;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: 1px;
  transition: all 0.2s ease;
}
.btn-premium:hover {
  background-color: #FF8533;
}

/* Scrollbar sombre élégante */
::-webkit-scrollbar {
  width: 10px;
  height: 10px;
}
::-webkit-scrollbar-track {
  background: #0A0A0A;
}
::-webkit-scrollbar-thumb {
  background: #2A2A2A;
  border-radius: 5px;
}
::-webkit-scrollbar-thumb:hover {
  background: #3A3A3A;
}

/* Sélection texte en orange (cohérence charte) */
::selection {
  background-color: #FF6800;
  color: white;
}

/* ─── STYLES D'IMPRESSION ──────────────────────────────────────────────────
   À l'impression, on repasse en blanc/noir pour économie d'encre
─────────────────────────────────────────────────────────────────────────── */
@media print {
  html, body, #root {
    background-color: white !important;
    color: black !important;
  }
  /* Masquer la navigation, header, footer pour l'impression */
  nav, header, footer, aside,
  [class*="navbar"], [class*="sidebar"], [class*="trial"], [class*="banner"] {
    display: none !important;
  }
  /* Forcer fond blanc sur les cartes sombres pour bonne lisibilité papier */
  .bg-slate-900, .bg-slate-950, .bg-emerald-900,
  [class*="bg-[#0"], [class*="bg-[#1"], [class*="bg-[#2"],
  [class*="bg-gradient"] {
    background: white !important;
    color: black !important;
    border: 1px solid #CCC !important;
  }
  /* Couleur du texte forcée en noir à l'impression */
  *, *::before, *::after {
    color: black !important;
  }
  /* Garder l'orange pour les titres importants à l'impression */
  h1, h2, h3, .text-orange-500, [class*="text-[#FF"] {
    color: #FF6800 !important;
  }
  /* Éviter les coupures dans les tableaux et cartes */
  table, .rounded-3xl, .rounded-2xl {
    page-break-inside: avoid;
  }
  /* Pas d'ombres ni d'animations à l'impression */
  * {
    box-shadow: none !important;
    animation: none !important;
    transition: none !important;
  }
}
