const STORE_DOMAIN = 'mqxwvxlx.mychariow.online'

const PACKS = [
  {
    id: 'credit_3',
    productId: 'prd_bu1cotto',
    name: 'Pack Starter',
    credits: 3,
    price: '600 F',
