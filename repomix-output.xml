                value={firstName} 
                onChange={(e) => setFirstName(e.target.value)} 
                />
            </div>
            <div className="space-y-1">
                <label className="text-[9px] font-black text-white/40 uppercase tracking-widest ml-1">Nom</label>
                <input 
                type="text" required placeholder="Koffi" 
